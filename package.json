{
  "name": "@readme/ua-platformer",
  "version": "3.0.0",
  "description": "Library to determine the platform of a given User Agent header.",
  "keywords": [
    "user agent"
  ],
  "bugs": {
    "url": "https://github.com/readmeio/ua-platformer/issues"
  },
  "license": "MIT",
  "author": "ReadMe <support@readme.io> (https://readme.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/readmeio/ua-platformer.git"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "format": "npx oxlint --fix && npx oxfmt --write",
    "lint": "npx oxlint && npx oxfmt --check",
    "prebuild": "rm -rf dist/",
    "prepack": "npm run build",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "ua-parser-js": "^2.0.1"
  },
  "devDependencies": {
    "@readme/oxlint-config": "^1.1.2",
    "@types/node": "^25.0.3",
    "@types/ua-parser-js": "^0.7.38",
    "@vitest/coverage-v8": "^4.1.2",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22"
  }
}
